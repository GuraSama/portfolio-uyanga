---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contact | Uyanga"
	description="A polished contact page for the portfolio template."
>
	<section class="page-hero panel">
		<div class="eyebrow">Contact</div>
		<h1>Ready to turn the site into your own portfolio?</h1>
		<p>
			Swap these placeholder details with your real contact information, then use the template as the
			base for your client-facing website.
		</p>
	</section>

	<div class="split-grid">
		<article class="panel empty-state">
			<h2>Email</h2>
			<p><a href="mailto:hello@uyanga.dev">hello@uyanga.dev</a></p>
			<p>Use this as a placeholder until you replace it with your own inbox.</p>
		</article>
		<article class="panel empty-state">
			<h2>Next steps</h2>
			<ul class="checklist">
				<li>Replace the sample projects with your real work.</li>
				<li>Update the about page copy and contact details.</li>
				<li>Use the dashboard to start publishing blog posts.</li>
			</ul>
		</article>
	</div>
</Layout>
