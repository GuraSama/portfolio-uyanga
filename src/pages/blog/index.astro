---
import { getCollection } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
	title="Blog | Uyanga"
	description="Read published articles managed through the Decap CMS writing workflow."
>
	<section class="page-hero panel">
		<div class="eyebrow">Blog Archive</div>
		<h1>Published writing, notes, and case studies.</h1>
		<p>
			Every post on this page comes from the same publishing workflow, so adding content stays
			simple.
		</p>
	</section>

	{
		posts.length > 0 ? (
			<div class="post-grid">
				{posts.map((post) => (
					<PostCard post={post} />
				))}
			</div>
		) : (
			<section class="panel empty-state">
				<h2>No posts published yet</h2>
				<p>Published posts will appear here automatically once they are added.</p>
			</section>
		)
	}
</Layout>
