---
import { getCollection } from 'astro:content';

import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const draftCount = posts.filter((post) => post.data.draft).length;
const featuredCount = posts.filter((post) => post.data.featured).length;
const recentPosts = posts.slice(0, 4);
---

<Layout
	title="Writer Dashboard | Uyanga"
	description="A quick launchpad for adding blog posts and managing content."
	noIndex={true}
>
	<section class="hero panel panel--hero">
		<div class="eyebrow">Writer Dashboard</div>
		<div class="hero-grid">
			<div class="stack">
				<h1>Add a new blog post in a few clicks.</h1>
				<p>
					This page acts like a lightweight admin dashboard. Use the shortcuts below to jump
					directly into Decap CMS where you can write, save drafts, upload images, and publish.
				</p>
				<p>
					For local editing, start both the site and the Decap proxy together with
					<code>npm run dev:cms</code>.
				</p>
				<div class="action-group">
					<a class="button" href="/admin/#/collections/blog/new">Write a new post</a>
					<a class="button is-secondary" href="/admin/#/collections/blog">Manage posts</a>
					<a class="button is-ghost" href="/admin/">Open CMS home</a>
				</div>
			</div>
			<div class="stat-grid">
				<article class="stat-card">
					<span class="eyebrow">Total Entries</span>
					<strong>{posts.length}</strong>
					<p>All blog files currently inside the content collection.</p>
				</article>
				<article class="stat-card">
					<span class="eyebrow">Drafts</span>
					<strong>{draftCount}</strong>
					<p>Draft posts stay hidden from the public blog until you publish them.</p>
				</article>
				<article class="stat-card">
					<span class="eyebrow">Featured</span>
					<strong>{featuredCount}</strong>
					<p>Featured posts can be highlighted on the homepage automatically.</p>
				</article>
				<article class="stat-card">
					<span class="eyebrow">Assets</span>
					<strong>Media</strong>
					<p>Upload cover images inside the CMS and reuse them in any post.</p>
				</article>
			</div>
		</div>
	</section>

	<div class="section-heading">
		<div>
			<div class="eyebrow">Shortcut Links</div>
			<h2>Common publishing tasks</h2>
		</div>
		<p>These shortcuts open the most useful places inside the CMS without extra clicking.</p>
	</div>

	<div class="dashboard-grid">
		<article class="panel empty-state">
			<h3>Start a new article</h3>
			<p>
				Open a fresh editor immediately, fill in the title and summary, then write the body in
				Markdown.
			</p>
			<p><a class="button is-secondary" href="/admin/#/collections/blog/new">New post editor</a></p>
		</article>
		<article class="panel empty-state">
			<h3>Upload or reuse images</h3>
			<p>Use the CMS media library when you want a cover image or inline asset for a post.</p>
			<p><a class="button is-secondary" href="/admin/#/media">Open media library</a></p>
		</article>
	</div>

	<div class="section-heading">
		<div>
			<div class="eyebrow">Workflow</div>
			<h2>Recommended publishing flow</h2>
		</div>
		<p>Keep the writing process consistent so your content stays clean and easy to manage.</p>
	</div>

	<div class="split-grid">
		<article class="panel empty-state">
			<h3>How to add a post</h3>
			<ol class="checklist">
				<li>Click “Write a new post” to open the blog editor.</li>
				<li>Add a title, description, publish date, and any tags.</li>
				<li>Upload an optional cover image if the post needs one.</li>
				<li>Switch on “Save as Draft” if you are not ready to publish.</li>
				<li>Publish when everything looks good.</li>
			</ol>
		</article>
		<article class="panel empty-state">
			<h3>What the CMS now handles</h3>
			<ol class="checklist">
				<li>Creates Markdown files inside `src/content/blog`.</li>
				<li>Stores uploaded media inside `public/uploads`.</li>
				<li>Supports homepage featuring and draft visibility.</li>
				<li>Feeds the public blog listing and each post page automatically.</li>
			</ol>
		</article>
	</div>

	<section class="section-heading">
		<div>
			<div class="eyebrow">Recent Entries</div>
			<h2>What is already in the collection</h2>
		</div>
		<p>Use the full post manager if you want to edit titles, dates, or publish state.</p>
	</section>

	<section class="panel dashboard-list">
		{
			recentPosts.length > 0 ? (
				recentPosts.map((post) => (
					<article class="dashboard-list__item">
						<div>
							<h3>{post.data.title}</h3>
							<div class="dashboard-list__meta">
								<span>
									{new Intl.DateTimeFormat('en-US', {
										month: 'short',
										day: 'numeric',
										year: 'numeric',
									}).format(post.data.date)}
								</span>
								<span>{post.data.author}</span>
								{post.data.draft ? (
									<span class="status-badge">Draft</span>
								) : (
									<span class="status-badge">Published</span>
								)}
							</div>
						</div>
						<div class="action-group">
							{!post.data.draft && (
								<a class="button is-ghost" href={`/blog/${post.id}/`}>
									View live post
								</a>
							)}
						</div>
					</article>
				))
			) : (
				<div>
					<h3>No posts yet</h3>
					<p>Use the new post shortcut above to create the first entry in the collection.</p>
				</div>
			)
		}
	</section>
</Layout>
