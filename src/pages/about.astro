---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About | Uyanga"
	description="An about page for the portfolio template, focused on editorial design and frontend delivery."
>
	<section class="page-hero panel">
		<div class="eyebrow">About</div>
		<h1>A calm, premium portfolio template for designers, freelancers, and studios.</h1>
		<p>
			This version of the site is built to feel intentional from the first screen: strong type, warm
			color, clear case studies, and a blog workflow that does not require editing code.
		</p>
	</section>

	<div class="split-grid">
		<article class="panel empty-state">
			<h2>What this template is built for</h2>
			<ul class="checklist">
				<li>Freelancers who want a cleaner portfolio than the default starter layout.</li>
				<li>Studios that need a mix of projects, writing, and direct contact paths.</li>
				<li>Founders who want an elegant static site with minimal maintenance.</li>
			</ul>
		</article>
		<article class="panel empty-state">
			<h2>What is included</h2>
			<ul class="checklist">
				<li>Homepage with portfolio-style positioning and selected work.</li>
				<li>Projects section with case study pages.</li>
				<li>Blog system backed by Astro content collections and Decap CMS.</li>
			</ul>
		</article>
	</div>
</Layout>
