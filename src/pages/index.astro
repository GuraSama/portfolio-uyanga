---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
const selectedProjects = (projects.filter((project) => project.data.featured).length
	? projects.filter((project) => project.data.featured)
	: projects
).slice(0, 3);
const latestPost = posts[0];
---

<Layout
	title="Uyanga | Portfolio Blog"
	description="A polished Astro blog with an easy writing dashboard and Decap CMS publishing flow."
>
	<section class="home-hero">
		<p class="eyebrow">Portfolio Blog</p>
		<h1>Uyanga builds clear, calm websites and writes about the process.</h1>
		<p>
			A simple portfolio for selected projects, occasional notes, and quick ways to get in touch.
		</p>
		<div class="action-group">
			<a class="button" href="/projects/">View projects</a>
			<a class="button is-secondary" href="/contact/">Contact</a>
		</div>
	</section>

	<div class="home-sections">
		<section class="home-block">
			<div class="section-heading section-heading--simple">
				<div>
					<p class="eyebrow">Selected Work</p>
					<h2>Recent projects</h2>
				</div>
				<a href="/projects/">All projects</a>
			</div>
			{
				selectedProjects.length > 0 ? (
					<ul class="simple-list">
						{selectedProjects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`}>
									<strong>{project.data.title}</strong>
									<span>{project.data.description}</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p>No project case studies yet.</p>
				)
			}
		</section>

		<section class="home-block">
			<div class="section-heading section-heading--simple">
				<div>
					<p class="eyebrow">Latest Writing</p>
					<h2>From the blog</h2>
				</div>
				<a href="/blog/">All posts</a>
			</div>
			{
				latestPost ? (
					<a class="latest-link" href={`/blog/${latestPost.id}/`}>
						<strong>{latestPost.data.title}</strong>
						<span>{latestPost.data.description}</span>
					</a>
				) : (
					<p>No published posts yet.</p>
				)
			}
		</section>
	</div>
</Layout>
